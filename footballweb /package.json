{
  "name": "footballweb",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace @footballweb/web",
    "dev:api": "npm run start:dev --workspace @footballweb/api",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @footballweb/api",
    "prisma:migrate:dev": "npm run prisma:migrate:dev --workspace @footballweb/api"
  }
}

