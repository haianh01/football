generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid()) @db.Uuid
  phone            String?    @unique @db.VarChar(32)
  email            String?    @unique @db.VarChar(255)
  display_name     String     @db.VarChar(120)
  avatar_url       String?
  country_code     String     @default("VN") @db.VarChar(2)
  timezone         String     @default("Asia/Ho_Chi_Minh") @db.VarChar(64)
  preferred_locale String     @default("vi-VN") @db.VarChar(16)
  status           UserStatus @default(active)
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @updatedAt @db.Timestamptz(6)

  user_identities            UserIdentity[]
  user_preferences           UserPreference?
  created_teams              Team[]       @relation("team_created_by")
  team_members               TeamMember[]
  target_user_team_invites   TeamInvite[] @relation("team_invite_target_user")
  created_team_invites       TeamInvite[] @relation("team_invite_created_by")
  created_match_posts        MatchPost[]  @relation("match_post_created_by")
  created_match_invitations  MatchInvitation[] @relation("match_invitation_created_by")
  created_matches            Match[]      @relation("match_created_by")
  match_participants         MatchParticipant[]

  @@index([status, created_at], map: "idx_users_status_created")
  @@map("users")
}

model UserIdentity {
  id               String           @id @default(uuid()) @db.Uuid
  user_id          String           @db.Uuid
  provider         IdentityProvider
  provider_subject String           @db.VarChar(255)
  created_at       DateTime         @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_subject])
  @@map("user_identities")
}

model UserPreference {
  user_id               String   @id @db.Uuid
  spoken_languages      Json     @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  notification_settings Json     @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  marketing_opt_in      Boolean  @default(false)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Team {
  id                 String         @id @default(uuid()) @db.Uuid
  name               String         @db.VarChar(120)
  slug               String         @unique @db.VarChar(140)
  short_code         String         @unique @db.VarChar(40)
  logo_url           String?
  description        String?
  home_country_code  String         @default("VN") @db.VarChar(2)
  home_state_code    String?        @db.VarChar(64)
  home_city_code     String?        @db.VarChar(64)
  home_district_code String?        @db.VarChar(64)
  default_locale     String         @default("vi-VN") @db.VarChar(16)
  skill_level_code   SkillLevelCode
  play_style_code    String?        @db.VarChar(64)
  primary_color      String?        @db.VarChar(32)
  secondary_color    String?        @db.VarChar(32)
  status             TeamStatus     @default(active)
  created_by         String         @db.Uuid
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @updatedAt @db.Timestamptz(6)

  created_by_user User         @relation("team_created_by", fields: [created_by], references: [id], onDelete: Restrict)
  team_members    TeamMember[]
  team_invites    TeamInvite[]
  match_posts     MatchPost[]
  sent_match_invitations MatchInvitation[] @relation("match_invitation_inviter_team")
  received_match_invitations MatchInvitation[] @relation("match_invitation_target_team")
  home_matches Match[] @relation("match_home_team")
  away_matches Match[] @relation("match_away_team")
  match_participants MatchParticipant[]

  @@index([home_city_code, skill_level_code], map: "idx_teams_city_skill")
  @@index([created_by, created_at], map: "idx_teams_created_by_created")
  @@map("teams")
}

model TeamMember {
  id                        String           @id @default(uuid()) @db.Uuid
  team_id                   String           @db.Uuid
  user_id                   String           @db.Uuid
  role                      TeamRole         @default(member)
  shirt_number              Int?
  primary_position_code     PositionCode?
  secondary_position_codes  Json             @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  joined_at                 DateTime         @db.Timestamptz(6)
  status                    TeamMemberStatus @default(active)
  attendance_rate           Decimal          @default(0) @db.Decimal(5, 2)
  current_debt_amount_minor BigInt           @default(0)
  currency_code             String           @default("VND") @db.VarChar(3)
  created_at                DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                DateTime         @updatedAt @db.Timestamptz(6)

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([team_id, role], map: "idx_team_members_team_role")
  @@index([user_id, status, joined_at], map: "idx_team_members_user_status_joined")
  @@map("team_members")
}

model TeamInvite {
  id             String       @id @default(uuid()) @db.Uuid
  team_id        String       @db.Uuid
  invite_type    InviteType
  target_user_id String?      @db.Uuid
  target_phone   String?      @db.VarChar(32)
  invite_code    String       @unique @db.VarChar(80)
  status         InviteStatus @default(pending)
  expires_at     DateTime     @db.Timestamptz(6)
  created_by     String       @db.Uuid
  created_at     DateTime     @default(now()) @db.Timestamptz(6)

  team            Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)
  target_user     User? @relation("team_invite_target_user", fields: [target_user_id], references: [id], onDelete: SetNull)
  created_by_user User  @relation("team_invite_created_by", fields: [created_by], references: [id], onDelete: Restrict)

  @@index([team_id, status], map: "idx_team_invites_team_status")
  @@index([target_phone], map: "idx_team_invites_target_phone")
  @@index([target_user_id, status], map: "idx_team_invites_target_user_status")
  @@index([expires_at], map: "idx_team_invites_expires_at")
  @@map("team_invites")
}

model MatchPost {
  id               String          @id @default(uuid()) @db.Uuid
  team_id          String          @db.Uuid
  title            String?         @db.VarChar(160)
  match_type       MatchType       @default(friendly)
  status           MatchPostStatus @default(open)
  urgency          UrgencyLevel    @default(normal)
  date             DateTime        @db.Date
  start_time       DateTime        @db.Time(6)
  end_time         DateTime?       @db.Time(6)
  timezone         String          @default("Asia/Ho_Chi_Minh") @db.VarChar(64)
  country_code     String          @default("VN") @db.VarChar(2)
  state_code       String?         @db.VarChar(64)
  city_code        String?         @db.VarChar(64)
  district_code    String?         @db.VarChar(64)
  venue_name       String?         @db.VarChar(160)
  venue_address    String?
  field_type       FieldType
  team_skill_min   SkillLevelCode
  team_skill_max   SkillLevelCode
  pitch_fee_rule   PitchFeeRule
  support_note     String?         @db.VarChar(160)
  currency_code    String          @default("VND") @db.VarChar(3)
  note             String?
  expires_at       DateTime?       @db.Timestamptz(6)
  created_by       String          @db.Uuid
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @updatedAt @db.Timestamptz(6)

  team            Team @relation(fields: [team_id], references: [id], onDelete: Restrict)
  created_by_user User @relation("match_post_created_by", fields: [created_by], references: [id], onDelete: Restrict)
  match_invitations MatchInvitation[]
  scheduled_match Match? @relation("match_source_post")

  @@index([status, city_code, date, field_type], map: "idx_match_posts_discovery")
  @@index([team_id, status, created_at], map: "idx_match_posts_team_status_created")
  @@index([created_by, created_at], map: "idx_match_posts_created_by_created")
  @@index([team_skill_min, team_skill_max], map: "idx_match_posts_skill")
  @@map("match_posts")
}

model MatchInvitation {
  id             String                @id @default(uuid()) @db.Uuid
  match_post_id  String                @db.Uuid
  inviter_team_id String               @db.Uuid
  target_team_id String                @db.Uuid
  status         MatchInvitationStatus @default(pending)
  note           String?               @db.VarChar(240)
  responded_at   DateTime?             @db.Timestamptz(6)
  created_by     String                @db.Uuid
  created_at     DateTime              @default(now()) @db.Timestamptz(6)
  updated_at     DateTime              @updatedAt @db.Timestamptz(6)

  match_post       MatchPost @relation(fields: [match_post_id], references: [id], onDelete: Cascade)
  inviter_team     Team      @relation("match_invitation_inviter_team", fields: [inviter_team_id], references: [id], onDelete: Restrict)
  target_team      Team      @relation("match_invitation_target_team", fields: [target_team_id], references: [id], onDelete: Restrict)
  created_by_user  User      @relation("match_invitation_created_by", fields: [created_by], references: [id], onDelete: Restrict)

  @@index([match_post_id, status], map: "idx_match_invitations_post_status")
  @@index([target_team_id, status], map: "idx_match_invitations_target_status")
  @@index([inviter_team_id, status], map: "idx_match_invitations_inviter_status")
  @@index([created_by, created_at], map: "idx_match_invitations_created_by_created")
  @@map("match_invitations")
}

model Match {
  id                   String      @id @default(uuid()) @db.Uuid
  source_match_post_id String?     @unique @db.Uuid
  home_team_id         String?     @db.Uuid
  away_team_id         String?     @db.Uuid
  match_type           MatchType   @default(friendly)
  status               MatchStatus @default(scheduled)
  date                 DateTime    @db.Date
  start_time           DateTime    @db.Time(6)
  end_time             DateTime?   @db.Time(6)
  timezone             String      @default("Asia/Ho_Chi_Minh") @db.VarChar(64)
  country_code         String      @default("VN") @db.VarChar(2)
  state_code           String?     @db.VarChar(64)
  city_code            String?     @db.VarChar(64)
  district_code        String?     @db.VarChar(64)
  venue_name           String?     @db.VarChar(160)
  venue_address        String?
  field_type           FieldType
  currency_code        String      @default("VND") @db.VarChar(3)
  created_by           String      @db.Uuid
  created_at           DateTime    @default(now()) @db.Timestamptz(6)
  updated_at           DateTime    @updatedAt @db.Timestamptz(6)

  source_match_post MatchPost? @relation("match_source_post", fields: [source_match_post_id], references: [id], onDelete: SetNull)
  home_team         Team?      @relation("match_home_team", fields: [home_team_id], references: [id], onDelete: SetNull)
  away_team         Team?      @relation("match_away_team", fields: [away_team_id], references: [id], onDelete: SetNull)
  created_by_user   User       @relation("match_created_by", fields: [created_by], references: [id], onDelete: Restrict)
  match_participants MatchParticipant[]

  @@index([home_team_id, date], map: "idx_matches_home_team_date")
  @@index([away_team_id, date], map: "idx_matches_away_team_date")
  @@index([status, date], map: "idx_matches_status_date")
  @@map("matches")
}

model MatchParticipant {
  id                String                @id @default(uuid()) @db.Uuid
  match_id          String                @db.Uuid
  user_id           String                @db.Uuid
  team_id           String?               @db.Uuid
  source_type       ParticipantSourceType
  role              ParticipantRole       @default(player)
  attendance_status AttendanceStatus      @default(invited)
  position_code     PositionCode?
  created_at        DateTime              @default(now()) @db.Timestamptz(6)
  updated_at        DateTime              @updatedAt @db.Timestamptz(6)

  match Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [team_id], references: [id], onDelete: SetNull)

  @@unique([match_id, user_id])
  @@index([match_id, attendance_status], map: "idx_match_participants_match_attendance")
  @@index([user_id, attendance_status], map: "idx_match_participants_user_attendance")
  @@index([team_id, attendance_status], map: "idx_match_participants_team_attendance")
  @@map("match_participants")
}

enum UserStatus {
  active
  suspended
  deleted
}

enum IdentityProvider {
  phone_otp
  google
  email
}

enum TeamStatus {
  active
  archived
  suspended
}

enum TeamRole {
  captain
  vice_captain
  treasurer
  member
}

enum TeamMemberStatus {
  active
  invited
  pending_approval
  inactive
  removed
}

enum InviteType {
  link
  code
  phone
  user
}

enum InviteStatus {
  pending
  accepted
  expired
  revoked
}

enum SkillLevelCode {
  L1_CASUAL
  L2_RECREATIONAL
  L3_INTERMEDIATE
  L4_ADVANCED
  L5_COMPETITIVE
}

enum PositionCode {
  GK
  CB
  LB
  RB
  DM
  CM
  AM
  LW
  RW
  ST
}

enum MatchType {
  friendly
  tactical
  mini_tournament
}

enum MatchPostStatus {
  open
  pending_confirmation
  matched
  cancelled
  expired
}

enum MatchInvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum MatchStatus {
  scheduled
  confirmed
  completed
  cancelled
}

enum ParticipantSourceType {
  team_member
  freelance_player
  guest
}

enum ParticipantRole {
  player
  captain
  goalkeeper
  manager
}

enum AttendanceStatus {
  invited
  confirmed
  declined
  checked_in
  absent
}

enum UrgencyLevel {
  low
  normal
  high
}

enum FieldType {
  five
  seven
  eleven
}

enum PitchFeeRule {
  share
  home_team_pays
  away_team_pays
  sponsor_supported
}
